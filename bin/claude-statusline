#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"

while [[ -L "$SOURCE" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"

  if [[ "$TARGET" != /* ]]; then
    SOURCE="$SOURCE_DIR/$TARGET"
  else
    SOURCE="$TARGET"
  fi
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

exec node "$PROJECT_ROOT/dist/main.js" "$@"
