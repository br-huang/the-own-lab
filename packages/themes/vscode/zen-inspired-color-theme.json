    "inputOption.activeBorder": "#D1CFC0",
    "inputValidation.errorBackground": "#1C1C1C",
    "inputValidation.errorBorder": "#EF4444",
    "badge.background": "#363636",
    "badge.foreground": "#E8E3DA",
    "progressBar.background": "#D1CFC0",
    "titleBar.activeBackground": "#101010",
    "titleBar.activeForeground": "#E8E3DA",
    "titleBar.inactiveBackground": "#141414",
    "titleBar.inactiveForeground": "#8E8A83",
    "activityBar.background": "#101010",
    "activityBar.foreground": "#E8E3DA",
    "activityBar.inactiveForeground": "#8E8A83",
    "activityBar.border": "#2C2C2C",
    "activityBarBadge.background": "#D1CFC0",
    "activityBarBadge.foreground": "#363636",
    "sideBar.background": "#101010",
    "sideBar.foreground": "#E8E3DA",
    "sideBar.border": "#2C2C2C",
