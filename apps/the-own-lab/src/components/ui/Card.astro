---
import { cn } from "ui";

interface Props {
  class?: string;
  as?: keyof HTMLElementTagNameMap;
}

const { class: className, as = "div", ...rest } = Astro.props;
const Tag = as;
---

<Tag
  data-slot="card"
  class={cn("bg-card text-card-foreground flex flex-col rounded-xl border shadow-sm", className)}
  {...rest}
>
  <slot />
</Tag>
